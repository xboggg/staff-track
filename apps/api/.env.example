# TimeTrack API Environment Variables
NODE_ENV=development
PORT=3500

# Database
DATABASE_URL=postgresql://timetrack:timetrack_dev@localhost:5434/timetrack?schema=public

# Redis
REDIS_URL=redis://:your_redis_password@localhost:6380

# JWT — CHANGE THESE IN PRODUCTION (use: openssl rand -base64 64)
JWT_SECRET=change-this-to-a-secure-random-string-in-production
JWT_REFRESH_SECRET=change-this-refresh-secret-too

# QR Code
QR_HMAC_SECRET=change-this-qr-hmac-secret

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=timetrack
MINIO_SECRET_KEY=timetrack_minio
MINIO_BUCKET=timetrack-uploads
