    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/qrcode": "^1.5.0",
    "@types/uuid": "^10.0.0",
    "prisma": "^6.4.0",
